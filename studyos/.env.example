# =========================================================================
# CROSS-PLATFORM ENVIRONMENT VARIABLES (Web & Mobile Expo)
# 
# For Web (Vite), prefix with `VITE_`
# For Mobile (Expo), prefix with `EXPO_PUBLIC_`
# Our `env.ts` config will automatically load whichever is present.
# =========================================================================

# --- AI MODEL API (Groq) ---
# NOTE: This single Groq API key handles ALL text features (schedule, chat, check-ins)
VITE_GROQ_API_KEY=your_groq_key_here
EXPO_PUBLIC_GROQ_API_KEY=your_groq_key_here

# --- AI MODEL API (Google Gemini) ---
# NOTE: Gemini 2.5 Flash is used exclusively for the Proof Photo Verification Engine.
VITE_GEMINI_API_KEY=your_gemini_api_key_here
EXPO_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here

# --- VOICE APIS FOR MOBILE EXPO NATIVE RECORDINGS ---
VITE_SARVAM_API_KEY=your_sarvam_api_key_here
EXPO_PUBLIC_SARVAM_API_KEY=your_sarvam_api_key_here

VITE_GOOGLE_SPEECH_API_KEY=your_google_cloud_json_here
EXPO_PUBLIC_GOOGLE_SPEECH_API_KEY=your_google_cloud_json_here

# --- FIREBASE DATABASE ---
VITE_FIREBASE_API_KEY=your_firebase_api_key
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key

VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com

VITE_FIREBASE_PROJECT_ID=your_project_id
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your_project_id

VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com

VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id

VITE_FIREBASE_APP_ID=your_app_id
EXPO_PUBLIC_FIREBASE_APP_ID=your_app_id

VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id

# --- APP CONFIG ---
VITE_ENVIRONMENT=development
EXPO_PUBLIC_ENVIRONMENT=development
