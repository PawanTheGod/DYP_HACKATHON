# --- AI MODEL API (Groq) ---
# NOTE: This single Groq API key handles ALL text features (schedule, chat, check-ins)
VITE_GROQ_API_KEY=your_groq_key_here

# --- AI MODEL API (Google Gemini) ---
# NOTE: Gemini 2.5 Flash is used exclusively for the Proof Photo Verification Engine.
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# --- FIREBASE DATABASE (Replaced localstorage) ---
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# --- APP CONFIG ---
VITE_APP_VERSION=1.0.0
VITE_ENVIRONMENT=development
